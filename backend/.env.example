# ===== LLM (Claude API) =====
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5

# ===== Google (Calendar / Gmail) =====
# 単一ユーザー・オフラインアクセス。Google Cloud で「デスクトップアプリ」種別の
# OAuth クライアントを作成し ID/SECRET を設定 → `npm run google:auth` を実行して
# 表示された GOOGLE_REFRESH_TOKEN をここに貼り付ける。
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# 今日の予定を集めるカレンダー ID（カンマ区切り。未指定なら primary のみ）
GOOGLE_CALENDAR_IDS=primary
# google:auth のループバックポート（デスクトップOAuthクライアントはlocalhost許可）
GOOGLE_OAUTH_PORT=5858
# Gmail の要対応候補を収集する範囲
GMAIL_LOOKBACK_DAYS=2
GMAIL_MAX_RESULTS=30

# ===== Canvas =====
# iCal フィード URL（ユーザーが貼り付け）
CANVAS_ICAL_URL=
# 締切を先読みする日数
CANVAS_LOOKAHEAD_DAYS=7

# ===== GitHub (Step 3.5) =====
# 昨日の commits/PR の取得に使うトークン。未設定なら gh CLI（`gh auth token`）から借りる。
GITHUB_TOKEN=
# TODO.md を読み取る対象（カンマ区切り）。owner/repo は GitHub API 経由、
# `/` `.` `~` で始まるパスはローカルの <path>/TODO.md を読む。
# 例: GITHUB_REPOS=~/Projects/ai-secretary,akiraak/vibeboard
GITHUB_REPOS=

# ===== APNs (iOS push) =====
# Apple Developer「Certificates, Identifiers & Profiles → Keys」で APNs 認証キーを作成し
# .p8 をダウンロードして APNS_P8_PATH に置く（Git にコミットしない）。
# KEY_ID = キー一覧に表示される Key ID / TEAM_ID = Membership の Team ID
# BUNDLE_ID = iOS アプリの Bundle Identifier（apns-topic ヘッダに使う）
# 設定後 `npm run apns:check`（`-- --fixture` ならネットワークなしで層だけ検証）
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_P8_PATH=
APNS_ENV=sandbox            # sandbox=開発ビルド | production=TestFlight/App Store 配布

# ===== Briefing =====
BRIEFING_HOUR=7             # America/Los_Angeles の時刻
TZ=America/Los_Angeles
BRIEFING_LANG=ja

# ===== API server =====
PORT=8787
API_SHARED_SECRET=          # POST /devices, GET /briefings/latest の Bearer

# ===== Storage =====
# SQLite ファイルパス（未指定なら backend/data/ai-secretary.db）
DB_PATH=
