# ===== LLM (Claude API) =====
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5

# ===== Google (Calendar / Gmail) =====
# 単一ユーザー・オフラインアクセス。Google Cloud で「デスクトップアプリ」種別の
# OAuth クライアントを作成し ID/SECRET を設定 → `npm run google:auth` を実行して
# 表示された GOOGLE_REFRESH_TOKEN をここに貼り付ける。
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# 今日の予定を集めるカレンダー ID（カンマ区切り。未指定なら primary のみ）。
# 管理画面（/admin の「収集カレンダー」）で保存すると DB の設定が優先され、この値は
# 未設定時のフォールバックになる
GOOGLE_CALENDAR_IDS=primary
# google:auth のループバックポート（デスクトップOAuthクライアントはlocalhost許可）
GOOGLE_OAUTH_PORT=5858
# カレンダーの予定を先読みする日数（週/月表示・変更検知の収集窓）
CALENDAR_LOOKAHEAD_DAYS=31
# Gmail の要対応候補を収集する範囲
GMAIL_LOOKBACK_DAYS=2
GMAIL_MAX_RESULTS=30

# ===== Canvas =====
# iCal フィード URL（ユーザーが貼り付け）
CANVAS_ICAL_URL=
# 締切を先読みする日数
CANVAS_LOOKAHEAD_DAYS=14

# ===== 買い物リスト (kitchen-living) =====
# 共有買い物リストの JSON API（トークン付き URL をそのまま貼る）。
# 例: https://kitchen.chobi.me/shopping-list?token=xxxx
# 未設定ならコレクタはスキップされ、HOME に買い物リストは表示されない
SHOPPING_LIST_URL=

# ===== GitHub (Step 3.5) =====
# 昨日の commits/PR の取得に使うトークン。未設定なら gh CLI（`gh auth token`）から借りる。
# アプリからの TODO 追加（POST /todos/repo が TODO.md へコミット）を使う場合は
# 対象リポジトリへの書き込み権限が必要（classic PAT は repo スコープ /
# fine-grained は Contents: Read and write）。読み取り専用だと追加時に 403 になる
GITHUB_TOKEN=
# TODO.md を読み取る対象（カンマ区切り）。owner/repo は GitHub API 経由、
# `/` `.` `~` で始まるパスはローカルの <path>/TODO.md を読む。
# `*` はトークンで見える全リポジトリ（fork・archived 除く）に展開し、
# TODO.md が無いリポジトリはスキップする。明示エントリとの併記も可。
# 例: GITHUB_REPOS=*  /  GITHUB_REPOS=~/Projects/ai-secretary,akiraak/vibeboard
GITHUB_REPOS=

# ===== APNs (iOS push) =====
# Apple Developer「Certificates, Identifiers & Profiles → Keys」で APNs 認証キーを作成し
# .p8 をダウンロードして APNS_P8_PATH に置く（Git にコミットしない）。
# KEY_ID = キー一覧に表示される Key ID / TEAM_ID = Membership の Team ID
# BUNDLE_ID = iOS アプリの Bundle Identifier（apns-topic ヘッダに使う）
# 設定後 `npm run apns:check`（`-- --fixture` ならネットワークなしで層だけ検証）
APNS_KEY_ID=
APNS_TEAM_ID=
# ios/project.yml の PRODUCT_BUNDLE_IDENTIFIER と一致させる
APNS_BUNDLE_ID=com.akiraak.ai-secretary
APNS_P8_PATH=
APNS_ENV=sandbox            # sandbox=開発ビルド | production=TestFlight/App Store 配布

# ===== Briefing =====
BRIEFING_HOUR=7             # America/Los_Angeles の時刻
TZ=America/Los_Angeles
BRIEFING_LANG=ja

# ===== API server =====
PORT=8787
API_SHARED_SECRET=          # POST /devices, GET /briefings/latest の Bearer
# /admin（管理画面）を有効にする明示フラグ（fail-safe。on 以外なら /admin* は 404）。
# 本番では前段（Cloudflare Access）で /admin を保護してから on にする。ローカルは on で可
ADMIN_ENABLED=

# ===== Storage =====
# SQLite ファイルパス（未指定なら backend/data/ai-secretary.db）
DB_PATH=
