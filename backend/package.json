{
  "name": "ai-secretary-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "朝ブリーフィングを収集・生成し iOS アプリへ APNs で push するバックエンド",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:init": "tsx src/db/init.ts",
    "google:auth": "tsx src/auth/googleGetToken.ts",
    "collectors:check": "tsx src/collectors/check.ts",
    "diff:check": "tsx src/jobs/calendarDiffCheck.ts",
    "todo-write:check": "tsx src/githubWriteCheck.ts",
    "llm:check": "tsx src/llm/check.ts",
    "apns:check": "tsx src/push/check.ts",
    "briefing": "tsx src/jobs/runBriefing.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
